# Express Variant Additions

## Additional Tech Stack
- Framework: Express.js
- Language: TypeScript / JavaScript
- Database: MongoDB (default) / PostgreSQL
- ODM/ORM: Mongoose / Prisma
- Validation: Joi / Zod

## Express-Specific Patterns

### Project Structure
```
src/
├── routes/              # Route definitions
│   ├── index.ts
│   ├── users.routes.ts
│   └── auth.routes.ts
├── controllers/         # Request handlers
│   ├── users.controller.ts
│   └── auth.controller.ts
├── services/            # Business logic
│   ├── users.service.ts
│   └── auth.service.ts
├── models/              # Database models
│   ├── User.ts
│   └── Product.ts
├── middleware/          # Custom middleware
│   ├── auth.ts
│   ├── validate.ts
│   └── errorHandler.ts
├── validators/          # Request validation
│   └── user.validator.ts
├── utils/               # Utilities
└── config/              # Configuration
    └── index.ts
```

### Route Template
```typescript
// routes/users.routes.ts
import { Router } from 'express';
import { UsersController } from '../controllers/users.controller';
import { validate } from '../middleware/validate';
import { createUserSchema, updateUserSchema } from '../validators/user.validator';
import { auth } from '../middleware/auth';

const router = Router();
const usersController = new UsersController();

router.get('/', auth, usersController.getAll);
router.get('/:id', auth, usersController.getById);
router.post('/', validate(createUserSchema), usersController.create);
router.put('/:id', auth, validate(updateUserSchema), usersController.update);
router.delete('/:id', auth, usersController.delete);

export default router;
```

### Controller Template
```typescript
// controllers/users.controller.ts
import { Request, Response, NextFunction } from 'express';
import { UsersService } from '../services/users.service';

export class UsersController {
  private usersService: UsersService;

  constructor() {
    this.usersService = new UsersService();
  }

  getAll = async (req: Request, res: Response, next: NextFunction) => {
    try {
      const { page = 1, limit = 10 } = req.query;
      const users = await this.usersService.findAll(
        Number(page),
        Number(limit)
      );
      res.json(users);
    } catch (error) {
      next(error);
    }
  };

  getById = async (req: Request, res: Response, next: NextFunction) => {
    try {
      const user = await this.usersService.findById(req.params.id);
      if (!user) {
        return res.status(404).json({ message: 'User not found' });
      }
      res.json(user);
    } catch (error) {
      next(error);
    }
  };

  create = async (req: Request, res: Response, next: NextFunction) => {
    try {
      const user = await this.usersService.create(req.body);
      res.status(201).json(user);
    } catch (error) {
      next(error);
    }
  };
}
```

### Service Template
```typescript
// services/users.service.ts
import { User, IUser } from '../models/User';

export class UsersService {
  async findAll(page: number, limit: number): Promise<{ users: IUser[]; total: number }> {
    const skip = (page - 1) * limit;
    const [users, total] = await Promise.all([
      User.find().skip(skip).limit(limit).lean(),
      User.countDocuments(),
    ]);
    return { users, total };
  }

  async findById(id: string): Promise<IUser | null> {
    return User.findById(id).lean();
  }

  async create(data: Partial<IUser>): Promise<IUser> {
    const user = new User(data);
    return user.save();
  }

  async update(id: string, data: Partial<IUser>): Promise<IUser | null> {
    return User.findByIdAndUpdate(id, data, { new: true }).lean();
  }

  async delete(id: string): Promise<boolean> {
    const result = await User.findByIdAndDelete(id);
    return !!result;
  }
}
```

### Error Handling Middleware
```typescript
// middleware/errorHandler.ts
import { Request, Response, NextFunction } from 'express';

interface AppError extends Error {
  statusCode?: number;
  status?: string;
}

export function errorHandler(
  err: AppError,
  req: Request,
  res: Response,
  next: NextFunction
) {
  err.statusCode = err.statusCode || 500;
  err.status = err.status || 'error';

  if (process.env.NODE_ENV === 'development') {
    res.status(err.statusCode).json({
      status: err.status,
      message: err.message,
      stack: err.stack,
    });
  } else {
    res.status(err.statusCode).json({
      status: err.status,
      message: err.message,
    });
  }
}
```

## Best Practices

### 1. Project Organization
- Use MVC-like structure
- Keep routes, controllers, services separate
- Use middleware for cross-cutting concerns

### 2. Error Handling
- Always use try/catch in async handlers
- Centralized error handling middleware
- Proper HTTP status codes

### 3. Validation
- Validate all inputs
- Use Joi or Zod schemas
- Return clear validation errors

### 4. Security
- Helmet for headers
- Rate limiting
- Input sanitization
- CORS configuration

