{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp-server"]
    },
    "simplemem": {
      "command": "docker",
      "args": [
        "exec", "-i", "simplemem-mcp",
        "python", "-m", "simplemem_mcp.server",
        "--project", "{{PROJECT_NAME}}"
      ]
    }
  }
}
